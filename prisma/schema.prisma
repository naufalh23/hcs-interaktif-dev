// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

// ============================================================
//  ENUMS
// ============================================================

enum Badge {
  ready
  indent
  hot
}

enum UnitStatus {
  available
  indent
  sold
}

// 'fixed'        → tampil harga normal
// 'free'         → tampil badge FREE
// 'contact_sales'→ tampil icon telp + contact_label
enum PriceDisplayMode {
  fixed
  free
  contact_sales
}

enum FieldType {
  text
  tel
  email
  textarea
  select
  radio
  checkbox
}

enum PaymentMethod {
  KPR_Bank      @map("KPR Bank")
  Cash_Keras    @map("Cash Keras")
  Cash_Bertahap @map("Cash Bertahap")
}

enum LeadStatus {
  new
  contacted
  negotiating
  booked
  cancelled
}

enum AdminRole {
  superadmin
  admin
  viewer
}

// ============================================================
//  MEDIA LIBRARY
//  Semua aset gambar/icon dikelola terpusat.
//  Tabel lain cukup simpan FK ke sini.
// ============================================================

model MediaLibrary {
  id           Int       @id @default(autoincrement())
  fileName     String    @map("file_name") @db.VarChar(255)
  url          String    @db.VarChar(500)
  mimeType     String    @map("mime_type") @db.VarChar(100)
  fileSizeKb   Int       @map("file_size_kb")
  altText      String?   @map("alt_text") @db.VarChar(255)
  uploadedById Int?      @map("uploaded_by_id")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  uploadedBy      AdminUser?      @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  // Relasi balik (satu media bisa dipakai di banyak tempat)
  kioskConfigLogos    KioskConfig[]   @relation("KioskLogo")
  kioskConfigHeroes   KioskConfig[]   @relation("KioskHero")
  pageSections        PageSection[]
  houseTypeCards      HouseType[]
  houseFacilities     HouseFacility[]
  unitCards           Unit[]
  addonIcons          AddonOption[]
  agentPhotos         Agent[]

  @@map("media_library")
}

// ============================================================
//  KIOSK CONFIG
//  Root konfigurasi per device/kiosk. Satu baris = satu kiosk.
// ============================================================

model KioskConfig {
  id          Int       @id @default(autoincrement())
  kioskId     String    @unique @map("kiosk_id") @db.VarChar(50)
  siteName    String    @map("site_name") @db.VarChar(100)
  tagline     String?   @db.VarChar(200)
  logoMediaId Int?      @map("logo_media_id")
  heroMediaId Int?      @map("hero_media_id")
  isActive    Boolean   @default(true) @map("is_active")
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  logo          MediaLibrary?   @relation("KioskLogo",  fields: [logoMediaId], references: [id], onDelete: SetNull)
  hero          MediaLibrary?   @relation("KioskHero",  fields: [heroMediaId], references: [id], onDelete: SetNull)

  stats         KioskStat[]
  pageSections  PageSection[]
  formSchemas   FormSchema[]
  leads         Lead[]
  sessions      KioskSession[]

  @@map("kiosk_config")
}

// ============================================================
//  KIOSK STATS
//  Counter di landing page (6 Cluster / 5 Fasilitas / 10+ Destinasi).
//  Dipisah agar admin bisa ubah nilai, label, urutan, atau tambah stat baru.
// ============================================================

model KioskStat {
  id            Int         @id @default(autoincrement())
  kioskConfigId Int         @map("kiosk_config_id")
  value         String      @db.VarChar(20)   // "6", "5", "10+"
  label         String      @db.VarChar(50)   // "Cluster", "Fasilitas", "Destinasi"
  sortOrder     Int         @default(0) @map("sort_order")

  kioskConfig   KioskConfig @relation(fields: [kioskConfigId], references: [id], onDelete: Cascade)

  @@map("kiosk_stats")
}

// ============================================================
//  PAGE SECTIONS
//  Konten teks & gambar per halaman yang bisa diubah dari CMS.
//  Layout/komponen tetap hardcoded di frontend.
//  page_slug: 'landing' | 'cluster' | 'unit' | 'customization' | 'booking'
//  section_key: identifier unik per blok dalam satu halaman,
//               misal 'hero', 'step_label', 'disclaimer', dsb.
// ============================================================

model PageSection {
  id            Int         @id @default(autoincrement())
  kioskConfigId Int         @map("kiosk_config_id")
  pageSlug      String      @map("page_slug") @db.VarChar(50)
  sectionKey    String      @map("section_key") @db.VarChar(100)
  title         String?     @db.VarChar(255)
  subtitle      String?     @db.Text
  mediaId       Int?        @map("media_id")
  extraContent  Json?       @map("extra_content")   // overflow fields yg tidak umum
  sortOrder     Int         @default(0) @map("sort_order")
  isVisible     Boolean     @default(true) @map("is_visible")

  kioskConfig   KioskConfig  @relation(fields: [kioskConfigId], references: [id], onDelete: Cascade)
  media         MediaLibrary? @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  @@unique([kioskConfigId, pageSlug, sectionKey])
  @@index([kioskConfigId, pageSlug])
  @@map("page_sections")
}

// ============================================================
//  HOUSE TYPES  (Tipe Hunian)
// ============================================================

model HouseType {
  id            Int       @id @default(autoincrement())
  cardMediaId   Int?      @map("card_media_id")
  cluster       String    @db.VarChar(100)
  name          String    @db.VarChar(100)    // "Tipe 60/84"
  buildingArea  Int       @map("building_area")
  landArea      Int       @map("land_area")
  floors        Int       @default(1)
  bedrooms      Int
  bathrooms     Int
  basePrice     BigInt    @map("base_price")
  badge         Badge
  badgeLabel    String    @map("badge_label") @db.VarChar(50)
  description   String?   @db.Text
  isActive      Boolean   @default(true) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order")

  cardMedia     MediaLibrary?   @relation(fields: [cardMediaId], references: [id], onDelete: SetNull)
  wallColors    WallColor[]
  facilities    HouseFacility[]
  units         Unit[]

  @@index([isActive, sortOrder])
  @@map("house_types")
}

// ============================================================
//  WALL COLORS  (Pilihan warna dinding per tipe)
// ============================================================

model WallColor {
  id          Int       @id @default(autoincrement())
  houseTypeId Int       @map("house_type_id")
  hex         String    @db.VarChar(7)
  name        String    @db.VarChar(50)
  sortOrder   Int       @default(0) @map("sort_order")

  houseType   HouseType @relation(fields: [houseTypeId], references: [id], onDelete: Cascade)

  @@map("wall_colors")
}

// ============================================================
//  HOUSE FACILITIES  (Fasilitas per tipe)
// ============================================================

model HouseFacility {
  id            Int           @id @default(autoincrement())
  houseTypeId   Int           @map("house_type_id")
  label         String        @db.VarChar(100)
  iconMediaId   Int?          @map("icon_media_id")

  houseType     HouseType     @relation(fields: [houseTypeId], references: [id], onDelete: Cascade)
  iconMedia     MediaLibrary? @relation(fields: [iconMediaId], references: [id], onDelete: SetNull)

  @@map("house_facilities")
}

// ============================================================
//  UNITS  (Kavling per tipe hunian)
// ============================================================

model Unit {
  id            Int           @id @default(autoincrement())
  houseTypeId   Int           @map("house_type_id")
  cardMediaId   Int?          @map("card_media_id")
  code          String        @unique @db.VarChar(20)    // "D-01"
  block         String        @db.VarChar(100)
  facing        String?       @db.VarChar(20)
  status        UnitStatus    @default(available)
  price         BigInt
  notes         String?       @db.VarChar(200)
  isFeatured    Boolean       @default(false) @map("is_featured")

  houseType     HouseType     @relation(fields: [houseTypeId], references: [id])
  cardMedia     MediaLibrary? @relation(fields: [cardMediaId], references: [id], onDelete: SetNull)
  leads         Lead[]

  @@index([houseTypeId])
  @@index([status])
  @@map("units")
}

// ============================================================
//  ADDON OPTIONS  (Opsi add-on kustomisasi Step 3)
// ============================================================

model AddonOption {
  id               Int              @id @default(autoincrement())
  iconMediaId      Int?             @map("icon_media_id")
  optionKey        String           @unique @map("option_key") @db.VarChar(50)
  name             String           @db.VarChar(100)
  description      String?          @db.VarChar(255)
  price            BigInt           @default(0)
  priceDisplayMode PriceDisplayMode @default(fixed) @map("price_display_mode")
  contactLabel     String?          @map("contact_label") @db.VarChar(100)  // untuk mode contact_sales
  isActive         Boolean          @default(true) @map("is_active")
  sortOrder        Int              @default(0) @map("sort_order")

  iconMedia        MediaLibrary?    @relation(fields: [iconMediaId], references: [id], onDelete: SetNull)
  leadAddons       LeadAddon[]

  @@index([isActive, sortOrder])
  @@map("addon_options")
}

// ============================================================
//  FORM SCHEMA  (Definisi form per kiosk, misal Form Pemesanan)
// ============================================================

model FormSchema {
  id              Int         @id @default(autoincrement())
  kioskConfigId   Int         @map("kiosk_config_id")
  formKey         String      @unique @map("form_key") @db.VarChar(50)   // 'booking_form'
  title           String      @db.VarChar(100)
  subtitle        String?     @db.VarChar(255)
  disclaimerText  String?     @map("disclaimer_text") @db.Text
  ctaLabel        String      @map("cta_label") @db.VarChar(50)          // "Konfirmasi Booking"
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  kioskConfig     KioskConfig @relation(fields: [kioskConfigId], references: [id], onDelete: Cascade)
  fields          FormField[]

  @@map("form_schema")
}

// ============================================================
//  FORM FIELDS  (Field-field di dalam form)
//  field_type: text | tel | email | textarea | select | radio | checkbox
//  col_span: 1 (setengah lebar) | 2 (full lebar)
//  validation_rules JSON contoh:
//    { "minLength": 10, "pattern": "^08[0-9]+$", "message": "Format tidak valid" }
//  options JSON contoh (untuk select/radio):
//    [{ "label": "KPR Bank", "value": "KPR_Bank" }, ...]
// ============================================================

model FormField {
  id               Int        @id @default(autoincrement())
  formSchemaId     Int        @map("form_schema_id")
  fieldKey         String     @map("field_key") @db.VarChar(50)     // "full_name", "phone"
  label            String     @db.VarChar(100)
  placeholder      String?    @db.VarChar(150)
  fieldType        FieldType  @map("field_type")
  isRequired       Boolean    @default(false) @map("is_required")
  options          Json?                                            // untuk select / radio
  validationRules  Json?      @map("validation_rules")
  colSpan          Int        @default(1) @map("col_span")          // 1 atau 2
  sortOrder        Int        @default(0) @map("sort_order")

  formSchema       FormSchema @relation(fields: [formSchemaId], references: [id], onDelete: Cascade)

  @@unique([formSchemaId, fieldKey])
  @@map("form_fields")
}

// ============================================================
//  AGENTS  (Marketing agent)
// ============================================================

model Agent {
  id            Int           @id @default(autoincrement())
  photoMediaId  Int?          @map("photo_media_id")
  name          String        @db.VarChar(100)
  code          String        @unique @db.VarChar(20)
  phone         String?       @db.VarChar(30)
  isActive      Boolean       @default(true) @map("is_active")
  isWalkin      Boolean       @default(false) @map("is_walkin")

  photoMedia    MediaLibrary? @relation(fields: [photoMediaId], references: [id], onDelete: SetNull)
  leads         Lead[]

  @@map("agents")
}

// ============================================================
//  LEADS  (Data customer & booking)
// ============================================================

model Lead {
  id                    Int           @id @default(autoincrement())
  bookingCode           String        @unique @map("booking_code") @db.VarChar(20)  // "HC-0001"
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Referensi kiosk sumber
  kioskConfigId         Int?          @map("kiosk_config_id")

  // Data pemesan
  fullName              String        @map("full_name") @db.VarChar(200)
  phone                 String        @db.VarChar(30)
  email                 String?       @db.VarChar(200)
  agentId               Int?          @map("agent_id")
  domicile              String?       @db.VarChar(100)

  // Properti yang dipilih
  unitId                Int           @map("unit_id")

  // Snapshot harga saat booking (immutable setelah tersimpan)
  basePrice             BigInt        @map("base_price")
  extraPrice            BigInt        @default(0) @map("extra_price")
  totalPrice            BigInt        @map("total_price")
  paymentMethod         PaymentMethod @map("payment_method")

  // Snapshot jawaban form (JSON agar tetap akurat walau form berubah)
  formAnswers           Json          @default("{}") @map("form_answers")

  // Tracking
  status                LeadStatus    @default(new)
  notes                 String?       @db.Text
  contactedAt           DateTime?     @map("contacted_at") @db.Timestamptz

  kioskConfig           KioskConfig?  @relation(fields: [kioskConfigId], references: [id], onDelete: SetNull)
  agent                 Agent?        @relation(fields: [agentId], references: [id], onDelete: SetNull)
  unit                  Unit          @relation(fields: [unitId], references: [id])
  addons                LeadAddon[]

  @@index([bookingCode])
  @@index([status])
  @@index([agentId])
  @@index([unitId])
  @@index([kioskConfigId])
  @@index([createdAt(sort: Desc)])
  @@map("leads")
}

// ============================================================
//  LEAD ADDONS  (Junction: addon yang dipilih per lead)
//  Dipisah dari JSON agar bisa di-query & diagregasi.
//  priceSnapshot: harga addon saat booking, tidak berubah walau admin edit harga.
// ============================================================

model LeadAddon {
  id              Int         @id @default(autoincrement())
  leadId          Int         @map("lead_id")
  addonOptionId   Int         @map("addon_option_id")
  priceSnapshot   BigInt      @map("price_snapshot")

  lead            Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  addonOption     AddonOption @relation(fields: [addonOptionId], references: [id])

  @@unique([leadId, addonOptionId])
  @@map("lead_addons")
}

// ============================================================
//  KIOSK SESSIONS  (State navigasi per sesi kiosk)
//  Menyimpan progress step 1-4 agar tidak hilang saat layar di-refresh.
//  selectionState JSON contoh:
//    { "houseTypeId": 2, "unitId": 5, "addons": [1, 3], "colorIndex": 2 }
// ============================================================

model KioskSession {
  id              Int         @id @default(autoincrement())
  kioskConfigId   Int         @map("kiosk_config_id")
  sessionToken    String      @unique @map("session_token") @db.VarChar(100)
  selectionState  Json        @default("{}") @map("selection_state")
  stepReached     Int         @default(1) @map("step_reached")
  startedAt       DateTime    @default(now()) @map("started_at") @db.Timestamptz
  lastActiveAt    DateTime    @default(now()) @updatedAt @map("last_active_at") @db.Timestamptz
  completed       Boolean     @default(false)

  kioskConfig     KioskConfig @relation(fields: [kioskConfigId], references: [id], onDelete: Cascade)

  @@index([kioskConfigId])
  @@index([lastActiveAt(sort: Desc)])
  @@map("kiosk_sessions")
}

// ============================================================
//  ADMIN USERS  (Pengguna CMS)
// ============================================================

model AdminUser {
  id            Int         @id @default(autoincrement())
  email         String      @unique @db.VarChar(200)
  passwordHash  String      @map("password_hash") @db.VarChar(255)
  fullName      String      @map("full_name") @db.VarChar(100)
  role          AdminRole   @default(admin)
  isActive      Boolean     @default(true) @map("is_active")
  lastLoginAt   DateTime?   @map("last_login_at") @db.Timestamptz
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  mediaUploads  MediaLibrary[]
  auditLogs     AuditLog[]

  @@map("admin_users")
}

// ============================================================
//  AUDIT LOGS  (Histori perubahan data oleh admin)
//  Mencatat before/after state untuk rollback & compliance.
// ============================================================

model AuditLog {
  id            Int         @id @default(autoincrement())
  adminUserId   Int         @map("admin_user_id")
  action        String      @db.VarChar(50)    // 'create' | 'update' | 'delete'
  entityType    String      @map("entity_type") @db.VarChar(50)  // 'HouseType', 'Unit', dsb
  entityId      Int         @map("entity_id")
  beforeState   Json?       @map("before_state")
  afterState    Json?       @map("after_state")
  ipAddress     String?     @map("ip_address") @db.VarChar(45)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  adminUser     AdminUser   @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
